# Dedicated VAIVIA travel assistant and Phase 2B Search grounding (server-side only)
GEMINI_ASSISTANT_API_KEY=
# Optional; defaults to gemini-3.5-flash when empty
GEMINI_ASSISTANT_MODEL=
AI_DAILY_MESSAGE_LIMIT=

# Phase 2A live place discovery (server-side Google Places API (New) key only)
GOOGLE_PLACES_API_KEY=

# Optional comma-separated Chrome extension IDs. Set in production once the
# Chrome Web Store ID is known to restrict account connection callbacks.
VAIVIA_BROWSER_EXTENSION_IDS=
