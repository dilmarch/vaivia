# Dedicated VAIVIA travel assistant and Phase 2B Search grounding (server-side only)
GEMINI_ASSISTANT_API_KEY=
# Optional; defaults to gemini-3.5-flash when empty
GEMINI_ASSISTANT_MODEL=
AI_DAILY_MESSAGE_LIMIT=

# Phase 2A live place discovery (server-side Google Places API (New) key only)
GOOGLE_PLACES_API_KEY=

# Optional comma-separated Chrome extension IDs. Set in production once the
# Chrome Web Store ID is known to restrict account connection callbacks.
VAIVIA_BROWSER_EXTENSION_IDS=

# Resend inbound travel-confirmation forwarding (server-side only)
RESEND_API_KEY=
RESEND_WEBHOOK_SECRET=
EMAIL_IMPORT_DOMAIN=
# Airport geocoding and time-zone lookup for import review (server-side only)
GOOGLE_MAPS_SERVER_API_KEY=

# VAIVIA Events payments (server-side standard Stripe account; never use Connect)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Protected Vercel Cron bearer used by scheduled maintenance
CRON_SECRET=
# Optional Events-only override; falls back to CRON_SECRET
EVENTS_MAINTENANCE_SECRET=

# Apple Wallet event-ticket signing (server-side only)
APPLE_WALLET_PASS_TYPE_ID=
APPLE_WALLET_TEAM_ID=
APPLE_WALLET_CERTIFICATE_BASE64=
APPLE_WALLET_PRIVATE_KEY_BASE64=
APPLE_WALLET_PRIVATE_KEY_PASSWORD=
APPLE_WALLET_WWDR_CERTIFICATE_BASE64=

# Google Wallet Event Ticket pass signing (server-side only)
GOOGLE_WALLET_ISSUER_ID=
GOOGLE_WALLET_SERVICE_ACCOUNT_EMAIL=
GOOGLE_WALLET_PRIVATE_KEY=
